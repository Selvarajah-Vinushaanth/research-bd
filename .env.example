
# ============================================
# AI Research Assistant - Environment Config
# ============================================

# --- Application ---
APP_NAME=AI_Research_Assistant
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://unvibrating-angeles-hoggishly.ngrok-free.dev

# --- Database ---
DATABASE_URL=postgresql://####:####@####/####?sslmode=require
POSTGRES_USER=####
POSTGRES_PASSWORD=####
POSTGRES_DB=####
POSTGRES_HOST=####
POSTGRES_PORT=####

# --- Redis ---
REDIS_URL=rediss://####:####@####:6379
REDIS_HOST=####
REDIS_PORT=6379

# --- JWT ---
JWT_SECRET_KEY=####
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Google Cloud ---
GCP_PROJECT_ID=####
GCP_BUCKET_NAME=####
# GCP_CREDENTIALS_PATH=####
# GOOGLE_APPLICATION_CREDENTIALS=####

# --- AI Models ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SUMMARIZER_MODEL=facebook/bart-large-cnn
QA_MODEL=deepset/roberta-base-squad2
EMBEDDING_DIMENSION=384

# --- Celery ---
CELERY_BROKER_URL=rediss://####:####@####:6379?ssl_cert_reqs=CERT_NONE
CELERY_RESULT_BACKEND=rediss://####:####@####:6379?ssl_cert_reqs=CERT_NONE

# --- Sentry ---
SENTRY_DSN=####

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- File Upload ---
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=.pdf

# --- Chunking ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# --- Hugging Face Inference API ---
HUGGINGFACE_API_TOKEN=####

# --- Google reCAPTCHA ---
RECAPTCHA_SECRET_KEY=####
RECAPTCHA_ENABLED=true
RECAPTCHA_MIN_SCORE=0.2
