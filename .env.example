# ============================================
# AI Research Assistant - Environment Config
# ============================================

# --- Application ---
APP_NAME=AI_Research_Assistant
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/research_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=research_assistant
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# --- JWT ---
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Google Cloud ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_BUCKET_NAME=research-assistant-papers
GCP_CREDENTIALS_PATH=/path/to/credentials.json
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# --- AI Models ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SUMMARIZER_MODEL=facebook/bart-large-cnn
QA_MODEL=deepset/roberta-base-squad2
EMBEDDING_DIMENSION=384

# --- Hugging Face Inference API ---
# Get your free token at https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=hf_your_token_here

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Sentry ---
SENTRY_DSN=

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- File Upload ---
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=.pdf

# --- Chunking ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50
